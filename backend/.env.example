# Server
PORT=5000
NODE_ENV=development
BACKEND_PUBLIC_URL=http://localhost:5000

# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASS>@cluster0.xxxxx.mongodb.net/<DB_NAME>?retryWrites=true&w=majority

# Auth / JWT
JWT_SECRET=<your_jwt_secret>
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=<your_jwt_refresh_secret>
JWT_REFRESH_EXPIRE=30d

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587git add backend/scripts/getGoogleToken.js

EMAIL_USER=<your_email@example.com>
EMAIL_PASS=<your_email_app_password>

# Third-party APIs / Keys
OPENAI_API_KEY=<your_openai_api_key>
STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>

# File upload / CDN
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Frontend URLs (comma separated)
FRONTEND_URL=http://localhost:3000
#FRONTEND_URLS=https://app.example.com,https://preview.example.com

# Logging / Misc
LOG_LEVEL=info